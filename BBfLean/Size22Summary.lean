/-- This cryptid is equivalent to #29, #41, and #430. -/
theorem hydra29
    (a : ℕ → ℕ) (b : ℕ → ℤ)
    (a_ini : a 0 = 1)
    (a_rec : ∀ n, a (n + 1) = if a n % 2 = 0 then 5 * (a n / 2) + 2 else 5 * (a n / 2))
    (b_ini : b 0 = 0)
    (b_rec : ∀ n, b (n + 1) = if a n % 2 = 0 then b n - 1 else b n + 2) :
    ∀ n, b n ≥ 0 := by
  sorry

